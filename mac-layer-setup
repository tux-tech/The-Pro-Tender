#!/bin/bash
# =============================================================================
#  mac-layer-setup.sh
#  macOS Compatibility Layer for Debian 13 (Trixie)
#  Makes your Debian box visible to all Macs on the network as a native peer.
#  Run as root or with sudo.
# =============================================================================

set -e

# ── Colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

ok()   { echo -e "${GREEN}[✔]${NC} $*"; }
info() { echo -e "${CYAN}[→]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
die()  { echo -e "${RED}[✘] FATAL: $*${NC}"; exit 1; }

# ── Root check ───────────────────────────────────────────────────────────────
[[ $EUID -ne 0 ]] && die "Please run with sudo:  sudo bash mac-layer-setup.sh"

# ── Grab the real user (the one who ran sudo) ────────────────────────────────
REAL_USER="${SUDO_USER:-$(logname 2>/dev/null || echo root)}"
REAL_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)

# ── Detect hostname ───────────────────────────────────────────────────────────
HOSTNAME_FQDN=$(hostname)
HOSTNAME_SHORT=$(hostname -s)

echo ""
echo -e "${BOLD}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║        macOS Compatibility Layer — Debian 13             ║${NC}"
echo -e "${BOLD}╚══════════════════════════════════════════════════════════╝${NC}"
echo ""
info "Running as root   : $(whoami)"
info "Installing for    : ${REAL_USER}"
info "Debian hostname   : ${HOSTNAME_SHORT}"
info "Share path        : /appleshare"
echo ""

# ─────────────────────────────────────────────────────────────────────────────
# STEP 1 – System update & package installation
# ─────────────────────────────────────────────────────────────────────────────
echo -e "${BOLD}[1/7] Updating package lists and installing packages…${NC}"
apt-get update -qq

PACKAGES=(
    samba               # SMB/CIFS file server with vfs_fruit
    samba-common        # Samba shared files (creates /etc/samba)
    samba-common-bin    # Samba tools (smbpasswd, testparm, etc.)
    avahi-daemon        # mDNS / Bonjour broadcaster
    avahi-utils         # avahi-browse, avahi-resolve helpers
    libnss-mdns         # Lets Debian resolve .local names itself
    netatalk            # AFP + Apple ZeroConf (legacy + icon support)
    attr                # getfattr / setfattr CLI tools
    acl                 # setfacl for fine-grained permissions
)

apt-get install -y --no-install-recommends "${PACKAGES[@]}" 2>&1 \
    | grep -E "^(Setting up|Unpacking|E:)" || true

# wsdd package name changed in Debian 13 — try both names
if apt-get install -y --no-install-recommends wsdd2 2>/dev/null; then
    ok "wsdd2 installed."
elif apt-get install -y --no-install-recommends wsdd 2>/dev/null; then
    ok "wsdd installed."
else
    warn "wsdd not available — Windows discovery won't work, but Macs are unaffected."
fi

ok "All packages installed."

# ─────────────────────────────────────────────────────────────────────────────
# STEP 2 – Create /appleshare with correct permissions
# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}[2/7] Creating /appleshare …${NC}"

mkdir -p /appleshare

# Setgid bit → new files inherit the group; sticky bit → users can't delete
# each other's files (like /tmp behaviour).
chown "${REAL_USER}:${REAL_USER}" /appleshare
chmod 2775 /appleshare

# Create a friendly README so Macs see something straight away
cat > /appleshare/README.txt <<EOF
Welcome to ${HOSTNAME_SHORT}
This share is hosted on a Debian 13 Linux machine.
It is fully compatible with macOS Finder tags, colours, and metadata.
EOF

ok "/appleshare created with correct permissions."

# ─────────────────────────────────────────────────────────────────────────────
# STEP 3 – Samba config (vfs_fruit Apple layer)
# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}[3/7] Configuring Samba with Apple vfs_fruit layer…${NC}"

# Ensure the directory exists (in case samba-common didn't create it)
mkdir -p /etc/samba

# Back up any existing config
cp /etc/samba/smb.conf /etc/samba/smb.conf.bak-$(date +%Y%m%d-%H%M%S) 2>/dev/null || true

cat > /etc/samba/smb.conf <<EOF
# =============================================================================
# Samba configuration — macOS Apple Compatibility Layer
# Generated by mac-layer-setup.sh on $(date)
# =============================================================================

[global]
   # ── Basic identity ──────────────────────────────────────────────────────
   server string        = ${HOSTNAME_SHORT} (Debian 13)
   workgroup            = WORKGROUP
   netbios name         = ${HOSTNAME_SHORT}

   # ── Security ────────────────────────────────────────────────────────────
   security             = user
   map to guest         = Bad User
   passdb backend       = tdbsam

   # ── Apple vfs_fruit layer (global) ──────────────────────────────────────
   # Load in correct dependency order: catia → fruit → streams_xattr
   vfs objects          = catia fruit streams_xattr

   # Activate Apple SMB2/3 extensions
   fruit:aapl           = yes

   # Store Apple metadata in NTFS-style alternate data streams (cleanest)
   fruit:metadata       = stream

   # Tell macOS this server is a "Mac Pro" rack server (native icon in Finder)
   fruit:model          = MacPro7,1

   # Server-side copy: fast file duplication without re-uploading
   fruit:copyfile       = yes

   # Rename semantics matching POSIX (prevents duplicate-file bugs on Mac)
   fruit:posix_rename   = yes

   # macOS metadata / extended attribute options
   fruit:veto_appledouble                    = no
   fruit:nfs_aces                            = no
   fruit:wipe_intentionally_left_blank_rfork = yes
   fruit:delete_empty_adfiles                = yes

   # ── macOS-friendly encoding ──────────────────────────────────────────────
   # catia maps problematic Windows reserved chars to Unicode equivalents
   catia:mappings = 0x22:0x201C,0x22:0x201D,0x27:0x2019,0x3a:0x2236

   # ── Log & misc ──────────────────────────────────────────────────────────
   log file             = /var/log/samba/log.%m
   max log size         = 1000
   logging              = file
   panic action         = /usr/share/samba/panic-action %d

   # Permissions
   create mask          = 0664
   directory mask       = 0775

# =============================================================================
# [AppleShare] — the main Mac-facing share
# =============================================================================
[AppleShare]
   comment              = Apple Share — ${HOSTNAME_SHORT}
   path                 = /appleshare
   browseable           = yes
   read only            = no
   guest ok             = yes

   # Per-share fruit overrides (inherits global vfs_fruit; these add extras)
   fruit:time machine   = no   ; set to yes if you want Time Machine here

EOF

ok "smb.conf written."

# ─────────────────────────────────────────────────────────────────────────────
# STEP 4 – Avahi / Bonjour service announcements
# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}[4/7] Configuring Avahi — Bonjour service announcements…${NC}"

# ── avahi-daemon.conf: allow the daemon to run properly ──────────────────────
sed -i 's/^#*enable-dbus=.*/enable-dbus=yes/' /etc/avahi/avahi-daemon.conf 2>/dev/null || true
sed -i 's/^#*use-ipv4=.*/use-ipv4=yes/'       /etc/avahi/avahi-daemon.conf 2>/dev/null || true
sed -i 's/^#*use-ipv6=.*/use-ipv6=yes/'       /etc/avahi/avahi-daemon.conf 2>/dev/null || true

# ── Service: SMB (shows up in Finder sidebar as a server) ────────────────────
cat > /etc/avahi/services/smb.service <<EOF
<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h</name>
  <service>
    <type>_smb._tcp</type>
    <port>445</port>
  </service>
</service-group>
EOF

# ── Service: SSH (shows in Finder "Remote Login" aware apps) ─────────────────
cat > /etc/avahi/services/ssh.service <<EOF
<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h (SSH)</name>
  <service>
    <type>_ssh._tcp</type>
    <port>22</port>
  </service>
</service-group>
EOF

# ── Service: AFP via Netatalk (makes Finder show a Mac icon) ─────────────────
cat > /etc/avahi/services/afp.service <<EOF
<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">%h</name>
  <service>
    <type>_afpovertcp._tcp</type>
    <port>548</port>
  </service>
  <!-- This makes macOS render the Debian box with a Mac Pro icon -->
  <service>
    <type>_device-info._tcp</type>
    <port>0</port>
    <txt-record>model=MacPro7,1</txt-record>
  </service>
</service-group>
EOF

# ── mDNS hostname resolution: add mdns4_minimal to nsswitch.conf ─────────────
# Ensures .local resolution works from Debian's own CLI too
if ! grep -q 'mdns4_minimal' /etc/nsswitch.conf; then
    sed -i '/^hosts:/ s/files/files mdns4_minimal [NOTFOUND=return]/' /etc/nsswitch.conf
fi

ok "Avahi service files written."

# ─────────────────────────────────────────────────────────────────────────────
# STEP 5 – Netatalk (AFP, for the authentic Mac icon / legacy support)
# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}[5/7] Configuring Netatalk (AFP)…${NC}"

NETATALK_CONF="/etc/netatalk/afp.conf"
if [[ -f "$NETATALK_CONF" ]]; then
    cp "$NETATALK_CONF" "${NETATALK_CONF}.bak-$(date +%Y%m%d-%H%M%S)"
    cat > "$NETATALK_CONF" <<EOF
; netatalk afp.conf — generated by mac-layer-setup.sh
[Global]
  hostname       = ${HOSTNAME_SHORT}
  zeroconf       = yes
  log level      = default:warn
  log file       = /var/log/netatalk/afpd.log

[AppleShare]
  path           = /appleshare
  time machine   = no
  read only      = no
EOF
    ok "Netatalk afp.conf configured."
else
    warn "afp.conf not found at expected path — skipping Netatalk config (it may still work with defaults)."
fi

# ─────────────────────────────────────────────────────────────────────────────
# STEP 6 – Samba user for the real user (guest also works but SMB user is better)
# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}[6/7] Setting up Samba user account…${NC}"

# Add user to Samba db.  We prompt for a password (cannot be avoided securely).
echo ""
echo -e "${YELLOW}  ┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}  │  Set a Samba password for '${REAL_USER}'.             │${NC}"
echo -e "${YELLOW}  │  This is the password you'll type on your Mac       │${NC}"
echo -e "${YELLOW}  │  when Finder asks for network credentials.          │${NC}"
echo -e "${YELLOW}  │  (Can be different from your Linux password)        │${NC}"
echo -e "${YELLOW}  └─────────────────────────────────────────────────────┘${NC}"
echo ""
smbpasswd -a "$REAL_USER" || warn "smbpasswd step skipped — you can add later with: sudo smbpasswd -a ${REAL_USER}"

ok "Samba user configured."

# ─────────────────────────────────────────────────────────────────────────────
# STEP 7 – Enable & restart all services
# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}[7/7] Enabling and starting services…${NC}"

SERVICES=(smbd nmbd avahi-daemon netatalk)
for svc in "${SERVICES[@]}"; do
    if systemctl list-unit-files | grep -q "^${svc}.service"; then
        systemctl enable  "$svc" --quiet
        systemctl restart "$svc" && ok "${svc} started." || warn "${svc} failed to start (check: systemctl status ${svc})"
    else
        warn "${svc} not found — skipping."
    fi
done

# wsdd (WS-Discovery) helps Windows / newer clients find the share too
if systemctl list-unit-files | grep -q '^wsdd.service'; then
    systemctl enable wsdd --quiet
    systemctl restart wsdd && ok "wsdd started." || true
fi

# ─────────────────────────────────────────────────────────────────────────────
# Install the xattr-safe aliases for the real user
# ─────────────────────────────────────────────────────────────────────────────
ALIAS_BLOCK="
# ── Mac-metadata-safe aliases (added by mac-layer-setup.sh) ──
alias cp='cp -a'
alias rsync='rsync -aX'
alias mac-check='getfattr -R -m com.apple /appleshare 2>/dev/null | grep \"# file:\" | sed \"s/# file: //\"'
"

for RC_FILE in "${REAL_HOME}/.bashrc" "${REAL_HOME}/.zshrc"; do
    if [[ -f "$RC_FILE" ]]; then
        if ! grep -q 'Mac-metadata-safe aliases' "$RC_FILE"; then
            echo "$ALIAS_BLOCK" >> "$RC_FILE"
            ok "Aliases added to $(basename $RC_FILE)"
        fi
    fi
done

# ─────────────────────────────────────────────────────────────────────────────
# Install the mac-check sanity script system-wide
# ─────────────────────────────────────────────────────────────────────────────
cat > /usr/local/bin/mac-check <<'SCRIPT'
#!/bin/bash
# mac-check — list files in /appleshare that carry Mac metadata (com.apple.*)
SEARCH_DIR="${1:-/appleshare}"
echo "Scanning ${SEARCH_DIR} for Mac metadata…"
echo "──────────────────────────────────────────"
getfattr -R -m "com.apple" "$SEARCH_DIR" 2>/dev/null \
    | grep "# file:" | sed 's/# file: //'
echo "──────────────────────────────────────────"
echo "Done."
SCRIPT
chmod +x /usr/local/bin/mac-check
ok "mac-check utility installed → run: mac-check"

# ─────────────────────────────────────────────────────────────────────────────
# Final summary
# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${GREEN}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${GREEN}║                    Setup Complete!                       ║${NC}"
echo -e "${BOLD}${GREEN}╚══════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "  ${BOLD}Your Debian box is now broadcasting as:${NC}"
echo -e "    • Bonjour name : ${CYAN}${HOSTNAME_SHORT}.local${NC}"
echo -e "    • NetBIOS name : ${CYAN}${HOSTNAME_SHORT}${NC}"
echo -e "    • Finder icon  : ${CYAN}Mac Pro${NC}"
echo ""
echo -e "  ${BOLD}Connect from your Mac:${NC}"
echo -e "    Finder → Go → Connect to Server:"
echo -e "      ${CYAN}smb://${HOSTNAME_SHORT}.local/AppleShare${NC}"
echo -e "    Or just open Finder — it should appear in the sidebar"
echo -e "    under 'Network' within ~30 seconds."
echo ""
echo -e "  ${BOLD}Share folder on this machine:${NC}"
echo -e "      ${CYAN}/appleshare${NC}"
echo ""
echo -e "  ${BOLD}Useful commands:${NC}"
echo -e "    mac-check           — list files with Mac metadata"
echo -e "    smbstatus           — see who is connected"
echo -e "    avahi-browse -a     — browse all Bonjour services on network"
echo -e "    testparm            — verify Samba config"
echo ""
echo -e "  ${BOLD}External drive (future):${NC}"
echo -e "    Mount your drive to ${CYAN}/appleshare${NC} via /etc/fstab"
echo -e "    Use Ext4 or Btrfs so Mac tags (xattrs) survive."
echo ""
